---
import { Font } from "astro:assets"
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import "@styles/global.css";
---
<!doctype html>
<html lang="en">
	<head>
		<Font cssVariable="--font-inter" preload />
		<Font cssVariable="--font-heading" preload/>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="Ferran Simon's CV website, showcasing his experience, studies, and projects in the field of software engineering and technology." />
		<title>Ferran Simon - CV</title>
	</head>
	<body>
		<div class="fixed h-full w-full bg-slate-950">
			<div class="absolute bottom-0 left-0 right-0 top-0 bg-[linear-gradient(to_right,#4f4f4f2e_1px,transparent_1px),linear-gradient(to_bottom,#4f4f4f2e_1px,transparent_1px)] bg-[size:14px_24px] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_0%,#000_70%,transparent_100%)]">
			</div>
		</div>
		<div class="relative overflow-y-auto flex flex-col max-h-screen">
				<Header />
				<slot />
				<Footer />
			</div>
	</body>
</html>

<style>
	:root {
		color-scheme: dark;
	}
	html,
	body {
		display: flex;
		flex-direction: column;
		min-height: 100vh;
	}
</style>
